# Copy this file to .env and fill in real values before running `docker compose up -d`.

# Postgres password (used by both the postgres and backend services)
POSTGRES_PASSWORD=change-me

# JWT signing secret — required, use a long random string
# e.g. generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-value

JWT_EXPIRES_IN=12h

# Allowed CORS origins for the API. Safe to leave as * since Nginx serves the
# client and the API on the same origin (no cross-origin requests happen in
# normal deployment) — tighten this if you ever call the API from elsewhere.
CORS_ORIGIN=*

# Public port Nginx listens on (change to 8080 etc. if 80 is already in use)
HTTP_PORT=80
