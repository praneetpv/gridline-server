# Postgres connection
DATABASE_URL=postgres://gridline:gridline@localhost:5432/gridline

# JWT signing secret — replace with a long random value in production
JWT_SECRET=change-me-to-a-long-random-value
JWT_EXPIRES_IN=12h

# HTTP + socket.io server port
PORT=4000

# Comma-separated list of allowed origins for CORS (the GRIDLINE web/mobile front-end)
CORS_ORIGIN=http://localhost:5173
